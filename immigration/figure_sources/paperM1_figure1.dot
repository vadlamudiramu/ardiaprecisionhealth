digraph AcoIQ {
  rankdir=LR;
  fontname="Helvetica";
  labelloc="b";
  fontsize=13;
  node [fontname="Helvetica", shape=box, style="rounded,filled", fontsize=12, margin="0.25,0.15"];
  edge [fontname="Helvetica", fontsize=10, color="#404040"];

  lims [label="LIMS Order Data", fillcolor="white", color="#595959"];
  attribution [label="ACO Beneficiary\nAttribution Lists", fillcolor="white", color="#595959"];

  subgraph cluster_l1 {
    label="Layer 1: Deterministic Policy Engine";
    fontname="Helvetica-Bold"; fontsize=11; color="#1f3864"; style="rounded"; labeljust="l";
    l1 [label="Quality measure spec.\nenforcement at order entry\n(HEDIS, ACO REACH,\nMSSP benchmarks)", fillcolor="#dce6f1", color="#1f3864"];
  }

  subgraph cluster_l2 {
    label="Layer 2: Generative Clinical Reasoning";
    fontname="Helvetica-Bold"; fontsize=11; color="#0f6657"; style="rounded"; labeljust="l";
    l2 [label="Natural-language\nutilization + population\nhealth reports", fillcolor="#d9f0ec", color="#0f6657"];
  }

  subgraph cluster_l3 {
    label="Layer 3: Predictive Analytics";
    fontname="Helvetica-Bold"; fontsize=11; color="#8a5a12"; style="rounded"; labeljust="l";
    l3 [label="Attributed beneficiary\nquality-gap risk scoring\n(outreach prioritization)", fillcolor="#fdf0d5", color="#8a5a12"];
  }

  dashboard [label="ACO Population Health\nDashboard (HL7 FHIR R4)", fillcolor="white", color="#595959"];

  lims -> l1;
  attribution -> l3;
  l1 -> l2 [label="order-entry data"];
  l2 -> dashboard;
  l3 -> dashboard;
  l3 -> l2 [style=dashed, label="gap risk feeds report"];

  label="Figure 1. AcoIQ three-layer architecture. Order-entry data enforces quality measure compliance in real time (Layer 1); attributed-beneficiary risk scoring (Layer 3) and generated reports (Layer 2) both feed the ACO population health dashboard.";
}
